---
import Link from "./Link.astro";

interface Props {
  title: string;
  description: string;
  image: {
    source: string;
    alt: string;
  };
  slug: string;
}

const { title, description, image, slug } = Astro.props;
---

<li
  class="grid grid-rows-7 drop-shadow-xl bg-slate-100 dark:bg-gray-800 pb-4 max-w-[40rem]"
>
  <img src={image.source} alt={image.alt} class="row-span-5 object-cover mb-4 w-full h-96" />
  <Link href={`/blog/${slug}`}>
    <h3 class="text-lg text-center uppercase px-2 mb-2">
      {title}
    </h3>
  </Link>
  <p class="px-4">{description}</p>
</li>
